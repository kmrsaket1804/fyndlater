# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
# Database (app accepts any of these)
POSTGRES_URL=postgresql://***
DATABASE_URL=postgresql://***
AUTH_SECRET=***
BASE_URL=https://your-domain.vercel.app

# Cashfree Payment Gateway
CASHFREE_APP_ID=your_app_id
CASHFREE_SECRET_KEY=your_secret_key
CASHFREE_ENVIRONMENT=sandbox
NEXT_PUBLIC_CASHFREE_ENVIRONMENT=sandbox

# Optional: Faye Instagram profile URL for "Save via Instagram" in dashboard
NEXT_PUBLIC_FAYE_INSTAGRAM_URL=https://www.instagram.com/your_faye_handle

# Google reCAPTCHA v3 (login, signup, contact form)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key

# Meta / Instagram (Faye bot)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_GRAPH_API_VERSION=v25.0
PAGE_ID=your_facebook_page_id
PAGE_ACCESS_TOKEN=your_page_access_token
# Instagram Login API only — do NOT use PAGE_ACCESS_TOKEN here (graph.instagram.com rejects Page tokens)
INSTAGRAM_ACCESS_TOKEN=
# Messaging API: facebook (Page token, default) or instagram (Instagram Login token only)
META_MESSAGING_API=facebook
# Optional: Facebook Login for Business configuration ID (replaces scope param)
# META_OAUTH_CONFIG_ID=
IG_USER_ID=your_instagram_professional_account_id
WEBHOOK_VERIFY_TOKEN=your_strong_private_verify_token
META_WEBHOOK_APP_SECRET=your_meta_app_secret

# Meta OAuth setup (one-time): visit /api/auth/meta after setting META_APP_ID + META_APP_SECRET
# Add https://fyndlater.com/api/auth/meta/callback to Meta App → Facebook Login → Valid OAuth Redirect URIs

# Reel processing pipeline (Apify + OpenAI + Vercel Queues)
APIFY_TOKEN=your_apify_token
OPENAI_API_KEY=your_openai_api_key
# Optional overrides
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# OPENAI_VISION_MODEL=gpt-4.1-mini
# FRAME_EVERY_SECONDS=2
# MAX_FRAMES=20
# RUNS_DIR=.runs
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Optional: legacy Stripe keys (not required for Cashfree)
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
